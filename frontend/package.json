    "check:ui": "node scripts/check-ui-structure.mjs && node scripts/check-diagnostics-matching.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "5.2.4",
    "@lucide/vue": "^1.17.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
